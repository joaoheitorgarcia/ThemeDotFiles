# --- Hybrid graphics defaults ---
# Keep Intel as the default GPU. Use nvrun for NVIDIA offload apps.
# export GBM_BACKEND=nvidia-drm
# export __GLX_VENDOR_LIBRARY_NAME=nvidia

# Avoid hardware cursor issues (white box / missing cursor)
export WLR_NO_HARDWARE_CURSORS=1

# NVIDIA renderer override, disabled globally so Intel remains default.
# export WLR_RENDERER=vulkan

# NVIDIA-only OpenGL tuning, disabled globally.
# export __GL_GSYNC_ALLOWED=0
# export __GL_VRR_ALLOWED=0
# export __GL_MaxFramesAllowed=1

# NVIDIA VAAPI override, disabled globally.
# export LIBVA_DRIVER_NAME=nvidia
export XDG_SESSION_TYPE=wayland
